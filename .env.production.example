# ──────────────────────────────────────────────
# SCALE PROTOCOL — Production Environment
# ──────────────────────────────────────────────
# Copy this to .env on your production server.
# All values below MUST be changed before deploying.

# ── Database ──
DATABASE_URL="postgresql://scaleuser:CHANGE_THIS_PASSWORD@postgres:5432/scaleprotocol?schema=public&connection_limit=20"

# ── Redis ──
REDIS_URL="redis://redis:6379"

# ── Robinhood Chain (Arbitrum Orbit L2, chain id 4663) ──
ROBINHOOD_RPC_URL="https://rpc.mainnet.chain.robinhood.com"
# REQUIRED: EVM private key (0x + 64 hex chars) for the protocol pool wallet
PROTOCOL_WALLET_PRIVATE_KEY="CHANGE_THIS"
# Public address of the pool wallet
PROTOCOL_WALLET=""
# $SCALE ERC-20 token address — set after the Noxa launch
FRONT_TOKEN_MINT=""
# Wallets whose $SCALE holdings count as locked supply (comma-separated)
FRONT_LOCKED_WALLETS=""
# Noxa-launched tokens with manually-verified fee redirects (comma-separated)
SCALE_VERIFIED_TOKENS=""
# Paid CoinGecko API key — flips market data to pro-api.coingecko.com (~500 req/min)
COINGECKO_API_KEY=""

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=""

# ── API Server ──
PORT=4001
NODE_ENV=production
# REQUIRED: Generate with `openssl rand -base64 64`
JWT_SECRET="CHANGE_THIS"
# CORS: comma-separated list of allowed origins
CORS_ORIGIN="https://www.scale.fun,https://scale.fun,https://www.front.fun,https://front.fun"

# ── Sybil resistance ──
SIGNUP_MAX_PER_DEVICE=1
SIGNUP_MAX_PER_IP=3

# ── Encryption ──
# REQUIRED: Generate with `openssl rand -hex 32`
ENCRYPTION_KEY="CHANGE_THIS"

# ── Protocol Config (basis points) ──
FLAT_FEE_BONDED=200
FLAT_FEE_RISING=300
FLAT_FEE_DEGEN=500
CREATOR_REVENUE_SHARE=3000
BURN_REVENUE_SHARE=2000
POOL_REVENUE_SHARE=5000
USER_PROFIT_LOCK_BPS=3000
# Burn batch threshold in wei (0.05 ETH)
BURN_THRESHOLD_WEI=50000000000000000

# ── Insurance Fund ──
INSURANCE_FUND_TARGET_BPS=200
INSURANCE_DEPOSIT_RATE_BPS=1000

# ── Docker Compose ──
POSTGRES_PASSWORD="CHANGE_THIS"
