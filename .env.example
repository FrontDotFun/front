# ──────────────────────────────────────────────
# SCALE PROTOCOL — Environment Variables
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scaleprotocol?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Robinhood Chain (Arbitrum Orbit L2, chain id 4663)
ROBINHOOD_RPC_URL="https://rpc.mainnet.chain.robinhood.com"
# EVM private key (0x + 64 hex chars) for the protocol pool wallet
PROTOCOL_WALLET_PRIVATE_KEY="0x-your-evm-private-key"
# Public address of the pool wallet (used by scanners/routes that only read)
PROTOCOL_WALLET="0x-your-protocol-wallet-address"
# $SCALE ERC-20 token address (from the Noxa launch)
FRONT_TOKEN_MINT="0x-your-scale-token-address"
# Wallets whose $SCALE holdings count as locked supply (comma-separated)
FRONT_LOCKED_WALLETS=""
# Noxa-launched tokens with manually-verified fee redirects (comma-separated)
SCALE_VERIFIED_TOKENS=""

# Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# API
API_PORT=4001
API_URL="http://localhost:4001"
JWT_SECRET="your-jwt-secret-change-in-production"

# Sybil resistance
SIGNUP_MAX_PER_DEVICE=1
SIGNUP_MAX_PER_IP=3

# Frontend
VITE_API_URL="http://localhost:4001"
VITE_WS_URL="ws://localhost:4001"

# Protocol Config
FLAT_FEE_BONDED=200
FLAT_FEE_RISING=300
FLAT_FEE_DEGEN=500
CREATOR_REVENUE_SHARE=3000
BURN_REVENUE_SHARE=2000
POOL_REVENUE_SHARE=5000
USER_PROFIT_LOCK_BPS=3000
# Burn batch threshold in wei (0.05 ETH)
BURN_THRESHOLD_WEI=50000000000000000

# Insurance Fund
INSURANCE_FUND_TARGET_BPS=200
INSURANCE_DEPOSIT_RATE_BPS=1000

# Encryption (for custodial wallets) — 32-byte hex
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"
